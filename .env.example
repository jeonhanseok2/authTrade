# ── Alpaca 증권사 API ─────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # 실전: https://api.alpaca.markets

# ── Google Gemini AI ──────────────────────────────────────────────────
# Google AI Studio(aistudio.google.com)에서 발급
GEMINI_API_KEY=your_gemini_api_key

# 모델명 재정의 (선택 — 기본값으로 두어도 됩니다)
# GEMINI_FLASH_MODEL=gemini-1.5-flash   # 일반 분석 (기본값)
# GEMINI_PRO_MODEL=gemini-1.5-pro       # 고도 추론 (기본값)

# ── Telegram 알림 ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── 토스증권 Open API ────────────────────────────────────────────────
# 토스증권 개발자센터(developers.tossinvest.com)에서 발급
# BROKER=toss 설정 시 사용. MODE=paper이면 실제 API 미호출.
TOSS_CLIENT_ID=your_toss_client_id
TOSS_CLIENT_SECRET=your_toss_client_secret
TOSS_ACCOUNT_SEQ=1234567          # 계좌 시퀀스 번호 (정수)
TOSS_PAPER_EQUITY=14800           # MODE=paper 시 가상 계좌 잔고 (USD)

# ── 실행 모드 ─────────────────────────────────────────────────────────
MODE=paper     # paper | live
BROKER=alpaca  # alpaca | toss
